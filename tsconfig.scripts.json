{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "outDir": ".ts-scripts"
  },
  "include": ["prisma/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
