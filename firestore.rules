rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções Auxiliares ───────────────────────────────────────

    function estaLogado() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function perfil() {
      return get(/databases/$(database)/documents/usuarios/$(uid())).data;
    }

    function temPerfil() {
      return exists(/databases/$(database)/documents/usuarios/$(uid()));
    }

    function portalSistema() {
      return temPerfil() && perfil().papelPortal == "SISTEMA" && perfil().ativo == true;
    }

    function portalEmpresaOuOperacional() {
      return temPerfil()
        && (perfil().papelPortal == "EMPRESA" || perfil().papelPortal == "OPERACIONAL")
        && perfil().ativo == true
        && perfil().empresaId is string
        && perfil().empresaId.size() > 0;
    }

    function pertenceAoTenant(empresaId) {
      return portalEmpresaOuOperacional() && perfil().empresaId == empresaId;
    }

    // Verifica se o chamador é gestor (portal EMPRESA) e pertence ao tenant
    function eGestorDoTenant(empresaId) {
      return temPerfil()
        && perfil().papelPortal == "EMPRESA"
        && perfil().ativo == true
        && perfil().empresaId == empresaId;
    }

    // Verifica se o documento alvo pertence ao mesmo tenant do chamador
    function mesmoTenantDoAlvo(userId) {
      return exists(/databases/$(database)/documents/usuarios/$(userId))
        && get(/databases/$(database)/documents/usuarios/$(userId)).data.empresaId == perfil().empresaId;
    }

    // ─── Coleção: usuarios/{userId} ─────────────────────────────

    match /usuarios/{userId} {
      // Leitura: próprio usuário OU gestor do mesmo tenant OU portal SISTEMA
      allow read: if estaLogado() && (
        userId == uid()
        || portalSistema()
        || (portalEmpresaOuOperacional() && perfil().papelPortal == "EMPRESA" && mesmoTenantDoAlvo(userId))
      );

      // Criação: apenas via Admin SDK (API routes) ou portal SISTEMA
      // Colaboradores não criam outros perfis; gestores criam via API route (Admin SDK)
      allow create: if estaLogado() && (
        userId == uid()
        || portalSistema()
      );

      // Atualização pelo próprio usuário: apenas campos seguros
      // Colaboradores NÃO podem alterar: papelPortal, papelEmpresa, empresaId, gestorId, papel, ativo
      allow update: if estaLogado() && userId == uid()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['papelPortal', 'papelEmpresa', 'empresaId', 'gestorId', 'papel', 'ativo']);

      // Atualização por gestor do mesmo tenant: pode alterar qualquer campo
      allow update: if estaLogado()
        && portalEmpresaOuOperacional()
        && perfil().papelPortal == "EMPRESA"
        && mesmoTenantDoAlvo(userId);

      // Atualização por portal SISTEMA: pode alterar qualquer campo
      allow update: if portalSistema();

      // Exclusão: apenas portal SISTEMA
      allow delete: if portalSistema();
    }

    // ─── Coleção: empresas/{empresaId} ──────────────────────────

    match /empresas/{empresaId} {
      allow read: if portalSistema() || pertenceAoTenant(empresaId);
      allow create, update, delete: if portalSistema();

      // Subcoleção: empresas/{empresaId}/usuarios/{docId}
      // Gestor do tenant pode ler e escrever; colaborador pode ler apenas o seu
      match /usuarios/{docId} {
        allow read: if portalSistema()
          || eGestorDoTenant(empresaId)
          || (estaLogado() && docId == uid() && pertenceAoTenant(empresaId));

        allow create, update: if portalSistema()
          || eGestorDoTenant(empresaId);

        allow delete: if portalSistema();
      }

      // Demais subcoleções da empresa (tarefas, rotinas, processos, etc.)
      match /{colecao}/{docId} {
        allow read, write: if portalSistema() || pertenceAoTenant(empresaId);
      }
    }
    
    match /financeiro_assinaturas/{document=**} {
      allow read, write: if portalSistema();
    }
    
    match /financeiro_aceites/{document=**} {
      allow read, write: if portalSistema();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
